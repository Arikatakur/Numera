<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Numera does not track users across apps/websites (no ads, no analytics). -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- Data the app collects is declared in App Store Connect's privacy
	     questionnaire (account email, user-entered finance data, purchase state). -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason APIs used directly by the app. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<!-- AppSettings persists the user's own preferences via UserDefaults;
			     it never reads/writes defaults belonging to other apps or the system. -->
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
