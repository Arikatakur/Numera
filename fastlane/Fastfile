default_platform(:ios)

SCHEME     = "Numera"
BUNDLE_ID  = "org.clientvault.numera"
XCODE_PROJ = "Numera.xcodeproj"

platform :ios do

  desc "Run tests"
  lane :test do
    run_tests(
      project: XCODE_PROJ,
      scheme:  SCHEME,
      device:  "iPhone 16",
      clean:   true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci

    api_key = app_store_connect_api_key(
      key_id:       ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id:    ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: "/tmp/AuthKey.p8",
      in_house:     false
    )

    match(
      type:           "appstore",
      app_identifier: BUNDLE_ID,
      readonly:       false,
      api_key:        api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  XCODE_PROJ,
      team_id:               ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity:    "Apple Distribution",
      profile_name:          "match AppStore #{BUNDLE_ID}",
      targets:               [SCHEME]
    )

    increment_build_number(
      build_number: ENV["GITHUB_RUN_NUMBER"] || Time.now.to_i.to_s,
      xcodeproj:    XCODE_PROJ
    )

    build_app(
      project:       XCODE_PROJ,
      scheme:        SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean:         true,
      output_name:   "Numera.ipa",
      xcargs:        "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')} " \
                     "CODE_SIGN_STYLE=Manual " \
                     "CODE_SIGN_IDENTITY='Apple Distribution'"
    )

    # Waits for App Store Connect processing so the changelog ("What to Test")
    # can be attached to the build. Test notes live in fastlane/changelog.txt.
    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: false,
      changelog:                         File.read(File.join(File.dirname(__FILE__), "changelog.txt")).strip,
      beta_app_description:              "Numera is a manual-first expense tracker: add expenses in seconds, " \
                                         "see clear insights and budgets, automate recurring transactions — " \
                                         "private by design.",
      beta_app_feedback_email:           "saleempay@hotmail.com"
    )
  end

  desc "Force-rotate certificates"
  lane :refresh_certs do
    setup_ci
    api_key = app_store_connect_api_key(
      key_id:       ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id:    ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: "/tmp/AuthKey.p8",
      in_house:     false
    )
    match(type: "appstore", app_identifier: BUNDLE_ID, force: true, api_key: api_key)
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end

end
